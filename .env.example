# VITE_EMAILJS_SERVICE_ID=service_436a87f
# VITE_EMAILJS_TEMPLATE_ID=template_4xzuxjd
# VITE_EMAILJS_PUBLIC_KEY=OIGAFNQuNN6-12DVo

VITE_EMAILJS_SERVICE_ID=service_436a87f
VITE_EMAILJS_TEMPLATE_ID=template_4xzuxjd
VITE_EMAILJS_PUBLIC_KEY=OIGAFNQuNN6-12DVo

