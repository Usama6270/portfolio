# Example env file. Create a local `.env.local` instead and keep it out of git.
# Copy values from your EmailJS dashboard and add the same keys in Vercel.
#
# Local (create .env.local in project root, do NOT commit):
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID=your_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# If you need a private key for server-side usage, store it as a non-VITE variable
# and do NOT expose it to the client. Example (server-only):
# EMAILJS_PRIVATE_KEY=your_private_key
